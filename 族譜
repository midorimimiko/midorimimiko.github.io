        // 創建按鈕
        const container = document.getElementById('mainContainer');
        for (let i = 1; i <= 17; i++) {
            const buttonDiv = document.createElement('div');
            buttonDiv.className = 'button-container';
            buttonDiv.id = `button${i}`;
            
