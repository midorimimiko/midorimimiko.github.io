            buttonDiv.style.left = positions[i].left + 'px';
            buttonDiv.style.top = positions[i].top + 'px';
            
            // 創建按鈕
            const button = document.createElement('button');
            button.textContent = buttonTexts.default[i];
            button.onclick = () => handleButtonClick(i);
            
            // 將按鈕添加到容器中
            buttonDiv.appendChild(button);
            container.appendChild(buttonDiv);
        }
        
        // 處理按鈕點擊的函數
        function handleButtonClick(buttonNumber) {
            if (currentButton === buttonNumber) {
                // 如果點擊的是同一個按鈕，恢復預設文字
                updateButtonTexts('default');
                currentButton = null;
            } else {
                // 如果點擊的是不同按鈕，更新文字
                updateButtonTexts(buttonNumber);
                currentButton = buttonNumber;
            }
        }
        
        // 更新所有按鈕文字的函數
        function updateButtonTexts(buttonNumber) {
            for (let i = 1; i <= 17; i++) {
                const buttonDiv = document.getElementById(`button${i}`);
                const button = buttonDiv.querySelector('button');
                button.innerHTML = buttonTexts[buttonNumber][i];  // 使用 innerHTML 而不是 textContent
            }
        }
